{
  "manifest_version": 3,
  "name": "AutoPoster Google Flow Helper",
  "version": "1.2.1",
  "description": "Hỗ trợ tự động hóa sinh ảnh/video trên Google Labs Flow từ ứng dụng AutoPoster: tự điền prompt & bấm Tạo cho từng phân đoạn.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "downloads",
    "sidePanel",
    "scripting",
    "debugger",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Đẩy nhanh sang Google Flow"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content-bridge.js"]
    },
    {
      "matches": [
        "https://labs.google/fx/*"
      ],
      "js": ["content-flow.js"]
    }
  ]
}
